# =============================================================================
# Standalone Git Bash (Mintty) Configuration
# =============================================================================

# Font & Typography
Font=Hack Nerd Font Mono
FontSize=11
FontWeight=400
FontSmoothing=default

# Cursor Settings
CursorType=block
CursorBlinks=yes
CursorColour=254,128,25

# Window & Interactions
Columns=80
Rows=30
OpaqueWhenFocused=yes
Locale=en_US
Charset=UTF-8
RightClickAction=paste

# =============================================================================
# Premium Gruvbox Dark Color Palette
# =============================================================================
#ForegroundColour=235,219,178
#BackgroundColour=40,40,40

# Black
#Black=40,40,40
#BoldBlack=146,131,116

# Red
#Red=204,36,29
#BoldRed=251,73,52

# Green
#Green=152,151,26
#BoldGreen=184,187,38

# Yellow
#Yellow=215,153,33
#BoldYellow=250,189,47

# Blue
#Blue=69,125,142
#BoldBlue=131,165,152

# Magenta
#Magenta=177,98,166
#BoldMagenta=211,134,155

# Cyan
#Cyan=104,157,106
#BoldCyan=142,192,124

# White
#White=168,153,132
#BoldWhite=235,219,178
