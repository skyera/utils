set nocompatible
filetype off

" --- Auto-install vim-plug ---
if has('nvim')
    let s:plug_path = stdpath('data') . '/site/autoload/plug.vim'
else
    let s:plug_path = has('win32') ? '~/vimfiles/autoload/plug.vim' : '~/.vim/autoload/plug.vim'
endif
let s:plug_path = expand(s:plug_path)

if empty(glob(s:plug_path))
    echo "Installing vim-plug..."
    let s:plug_url = 'https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim'
    let s:dir = fnamemodify(s:plug_path, ':h')
    if !isdirectory(s:dir) | silent! call mkdir(s:dir, 'p') | endif
    if executable('curl')
        silent execute '!curl -fLo ' . shellescape(s:plug_path) . ' --create-dirs ' . s:plug_url
    elseif has('win32')
        silent execute '!powershell -Command "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; Invoke-WebRequest -Uri ' . s:plug_url . ' -OutFile ' . shellescape(s:plug_path) . '"'
    endif
    autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

call plug#begin()
