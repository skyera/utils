" --- Windows Python DLL Support ---
if has('win32') && !has('nvim')
    let s:python_exe = exepath('python.exe')
    if !empty(s:python_exe)
        let s:python_home = fnamemodify(s:python_exe, ':h')
        let &pythonthreehome = s:python_home
        let s:dlls = globpath(s:python_home, 'python3*.dll', 0, 1)
        for s:dll in s:dlls
            if s:dll !~? 'python3\.dll$'
                let &pythonthreedll = s:dll
                break
            endif
        endfor
    endif
endif

