# =============================================================================
# ENVIRONMENT
# =============================================================================

# Configuration options for prompt selection
SH_PROMPT_STYLE=${SH_PROMPT_STYLE:-"custom"} # options: "custom" or "oh-my-bash"
OSH_THEME=${OSH_THEME:-"font"}             # oh-my-bash theme to use

# Customize what oh-my-bash loads when active:
OMB_PLUGINS=${OMB_PLUGINS:-"git bash-preexec"}
OMB_ALIASES=${OMB_ALIASES:-"general"}
OMB_COMPLETIONS=${OMB_COMPLETIONS:-"git npm pip"}

# System detection (avoiding uname subprocess call which is slow on Windows/Git Bash)
_IS_WINDOWS=false
[[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" || "$OSTYPE" == "win32" ]] && _IS_WINDOWS=true

# Container detection
is_container() {
    # On Windows, we're likely not in a container of interest for this script
    $_IS_WINDOWS && return 1
    [ -f /.dockerenv ] || [ -f /.containerenv ] || grep -q "docker\|lxc\|kubepods" /proc/1/cgroup 2>/dev/null || [ -n "$CONTAINER" ] || [ -n "$KUBERNETES_SERVICE_HOST" ]
}

# Cache container status
_IS_CONTAINER=false
is_container && _IS_CONTAINER=true

# Git configuration overrides for containers or old git versions
# zdiff3 requires Git 2.35+
if $_IS_WINDOWS; then
    _GIT_SUPPORTS_ZDIFF3=true
else
    _GIT_VERSION=$(git version 2>/dev/null)
    _GIT_VERSION=${_GIT_VERSION#git version }
    IFS='.' read -r _GIT_MAJOR _GIT_MINOR _rest <<< "$_GIT_VERSION"
    _GIT_MAJOR=${_GIT_MAJOR:-0}
    _GIT_MINOR=${_GIT_MINOR:-0}

    if [ "$_GIT_MAJOR" -lt 2 ] || { [ "$_GIT_MAJOR" -eq 2 ] && [ "$_GIT_MINOR" -lt 35 ]; }; then
        _GIT_SUPPORTS_ZDIFF3=false
    else
        _GIT_SUPPORTS_ZDIFF3=true
    fi
fi

if $_IS_CONTAINER || ! $_GIT_SUPPORTS_ZDIFF3; then
    # Git < 2.35 (e.g. Git 2.25 in Ubuntu 20.04) does not support zdiff3
    # Git < 2.37 does not support push.autoSetupRemote
    # Use an alias because GIT_CONFIG_PARAMETERS format changed between Git versions
    _GIT_EXTRA_ARGS=""
    if ! $_GIT_SUPPORTS_ZDIFF3; then
        _GIT_EXTRA_ARGS="$_GIT_EXTRA_ARGS -c merge.conflictstyle=diff3"
    fi
    if [ "$_GIT_MAJOR" -lt 2 ] || { [ "$_GIT_MAJOR" -eq 2 ] && [ "$_GIT_MINOR" -lt 37 ]; }; then
        _GIT_EXTRA_ARGS="$_GIT_EXTRA_ARGS -c push.autoSetupRemote=false"
    fi
    
    if [ -n "$_GIT_EXTRA_ARGS" ]; then
        alias git="git $_GIT_EXTRA_ARGS"
    fi
fi

# Git Pager (delta) detection
# Avoid running delta --version if possible, or only do it once
if ! $_IS_CONTAINER && command -v delta >/dev/null 2>&1; then
    export GIT_PAGER="delta"
else
    export GIT_PAGER="less"
fi

# Optimize git commands on WSL mounted Windows drives by routing to git.exe
if [[ -n "$WSL_DISTRO_NAME" ]]; then
    git() {
        # If called from prompt scripts, bypass the wrapper to use native git
        # This keeps the shell prompt instantaneous (10ms) while optimizing manual CLI commands
        local f
        if [[ -n "$BASH_VERSION" ]]; then
            for f in "${FUNCNAME[@]}"; do
                if [[ "$f" == "__git_ps1" || "$f" == "_set_bash_prompt_vars" ]]; then
                    command git "$@"
                    return
                fi
            done
        elif [[ -n "$ZSH_VERSION" ]]; then
            for f in "${funcstack[@]}"; do
                if [[ "$f" == "vcs_info" || "$f" == "precmd_vcs_info" ]]; then
                    command git "$@"
                    return
                fi
            done
        fi

        if [[ "$PWD" == /mnt/* ]] && command -v git.exe >/dev/null 2>&1; then
            git.exe "$@"
        else
            command git "$@"
        fi
    }
fi

# Windows-specific overrides
if $_IS_WINDOWS; then
    # Use Windows-installed Neovim/Vim if available
    command -v nvim.exe >/dev/null 2>&1 && alias nvim='nvim.exe'
    command -v vim.exe >/dev/null 2>&1 && alias vim='vim.exe'
    alias vi='nvim'

    # Set Yazi file type detection helper path
    if [ -f "C:/Program Files/Git/usr/bin/file.exe" ]; then
        export YAZI_FILE_ONE="C:/Program Files/Git/usr/bin/file.exe"
    elif [ -f "C:/Program Files (x86)/Git/usr/bin/file.exe" ]; then
        export YAZI_FILE_ONE="C:/Program Files (x86)/Git/usr/bin/file.exe"
    elif [ -f "C:/cygwin64/bin/file.exe" ]; then
        export YAZI_FILE_ONE="C:/cygwin64/bin/file.exe"
    fi

    # Use Windows-installed Python if available (wrapped in winpty for Git Bash console compatibility)
    command -v python.exe >/dev/null 2>&1 && alias python='winpty python.exe'
    command -v python3.exe >/dev/null 2>&1 && alias python3='winpty python3.exe'
    command -v pip.exe >/dev/null 2>&1 && alias pip='winpty pip.exe'

    # mpv media player (run via winpty for Git Bash console compatibility)
    alias mpv='winpty /c/ProgramData/chocolatey/lib/mpvio.install/tools/mpv.exe'

    # Enable native Windows symlinks in MSYS2/Git Bash.
    # NOTE: Windows requires "Developer Mode" to be enabled for standard users to create symlinks.
    # Enable it via: Windows Settings -> System -> For developers -> Toggle "Developer Mode" ON.
    export MSYS="winsymlinks:nativestrict"
fi

# PATH
# Safely add to PATH without creating duplicate entries upon sourcing/reloading
[[ ":$PATH:" != *":$HOME/bin:"* ]] && export PATH="$HOME/bin:$PATH"
[[ ":$PATH:" != *":$HOME/.local/share/forgit/bin:"* ]] && export PATH="$HOME/.local/share/forgit/bin:$PATH"

# Editor & Tool detection (cached)
if [[ -z "$_EDITOR" ]]; then
    if command -v nvim >/dev/null 2>&1; then
        _EDITOR="nvim"
    elif command -v vim >/dev/null 2>&1; then
        _EDITOR="vim"
    else
        _EDITOR="vi"
    fi
fi
export EDITOR="$_EDITOR"
export VISUAL="$EDITOR"

# Detect Neovim binary path if not already set (cached, fast builtin check)
if [[ -z "$_NEOVIM_BIN" ]]; then
    if $_IS_WINDOWS; then
        _NEOVIM_BIN=$(command -v nvim.exe)
    else
        _NEOVIM_BIN=$(command -v nvim)
    fi
fi
export NEOVIM_BIN="$_NEOVIM_BIN"

# Tool configs
export RIPGREP_CONFIG_PATH=$HOME/.ripgreprc
# Safely prepend include and library paths without duplicates or trailing colons
_add_path_to_var() {
    local var_name="$1"
    local dir_path="$2"
    if [[ -d "$dir_path" ]]; then
        eval "local current_val=\$$var_name"
        if [[ ":$current_val:" != *":$dir_path:"* ]]; then
            if [[ -z "$current_val" ]]; then
                eval "export $var_name=\"$dir_path\""
            else
                eval "export $var_name=\"$dir_path:$current_val\""
            fi
        fi
    fi
}

for _p in "$HOME/test/doctest/doctest" \
          "$HOME/test/nanobench/src/include" \
          "$HOME/test/FakeIt/single_header/doctest" \
          "$HOME/test/json/single_include" \
          "$HOME/test/stb" \
          "$HOME/test/LuaBridge/Source" \
          "$HOME/test/luajit/src"; do
    _add_path_to_var CPLUS_INCLUDE_PATH "$_p"
done

_add_path_to_var LIBRARY_PATH "$HOME/test/luajit/src"

unset -f _add_path_to_var
unset _p

# Terminal & Display
[[ -z "$TMUX" ]] && export TERM=xterm-256color
export PROMPT_DIRTRIM=2
export LIBGL_ALWAYS_SOFTWARE=1

# =============================================================================
# PROMPT CONFIGURATION (Git-Aware & Colorized)
# =============================================================================

# Disable Conda's default unstyled PS1 prefix injection
export CONDA_CHANGEPS1=false

# Cached tool check for fallback prompt
_HAS_GIT=false && command -v git >/dev/null 2>&1 && _HAS_GIT=true

# Unicode check to choose a modern chevron or classic fallback
_PROMPT_CHAR="\$"
if [[ "$LANG" == *".UTF-8"* || "$LANG" == *".utf8"* || "$LC_ALL" == *".UTF-8"* ]]; then
    _PROMPT_CHAR="❯"
fi

if [[ "$SH_PROMPT_STYLE" == "oh-my-bash" && -n "$BASH_VERSION" ]]; then
    export OSH=$HOME/.oh-my-bash
    if [ ! -d "$OSH" ]; then
        if command -v git >/dev/null 2>&1; then
            echo -e "\033[32m[mybashrc] ~/.oh-my-bash not found. Automatically cloning oh-my-bash...\033[0m"
            git clone --depth=1 https://github.com/ohmybash/oh-my-bash.git "$OSH"
        else
            echo -e "\033[31m[mybashrc] Error: git is required to download oh-my-bash.\033[0m"
        fi
    fi
    
    if [ -f "$OSH/oh-my-bash.sh" ]; then
        # Map our config to oh-my-bash expected arrays
        plugins=($OMB_PLUGINS)
        aliases=($OMB_ALIASES)
        completions=($OMB_COMPLETIONS)
        source "$OSH/oh-my-bash.sh"
    else
        echo -e "\033[33m[mybashrc] Note: oh-my-bash could not be loaded. Falling back to custom prompt.\033[0m"
        SH_PROMPT_STYLE="custom"
    fi
fi

if [[ -n "$BASH_VERSION" ]]; then
    # Load git-sh-prompt if available
    if ! declare -F __git_ps1 >/dev/null 2>&1; then
        for _prompt_script in "/usr/lib/git-core/git-sh-prompt" \
                              "/usr/share/git-core/git-sh-prompt" \
                              "/etc/bash_completion.d/git-prompt" \
                              "/opt/homebrew/etc/bash_completion.d/git-prompt.sh" \
                              "/usr/local/etc/bash_completion.d/git-prompt.sh" \
                              "/Library/Developer/CommandLineTools/usr/share/git-core/git-sh-prompt" \
                              "/etc/profile.d/git-prompt.sh" \
                              "/mingw64/share/git/completion/git-prompt.sh"; do
            if [ -f "$_prompt_script" ]; then
                source "$_prompt_script"
                break
            fi
        done
    fi

    if declare -F __git_ps1 >/dev/null 2>&1; then
        # Configure Git prompt features
        export GIT_PS1_SHOWDIRTYSTATE=true       # '*' for unstaged, '+' for staged changes
        export GIT_PS1_SHOWSTASHSTATE=true       # '$' if stash exists
        export GIT_PS1_SHOWUNTRACKEDFILES=true   # '%' if untracked files exist
        export GIT_PS1_SHOWUPSTREAM="auto"       # '<', '>', '=', '<>' compared to upstream
        export GIT_PS1_STATESEPARATOR=" "
        
        _set_bash_prompt_vars() {
            local exit_code=$?
            
            # Dynamically adjust Git prompt features for WSL mounted drives to avoid severe lag
            if [[ -n "$WSL_DISTRO_NAME" && "$PWD" == /mnt/* ]]; then
                GIT_PS1_SHOWDIRTYSTATE=""
                GIT_PS1_SHOWSTASHSTATE=""
                GIT_PS1_SHOWUNTRACKEDFILES=""
                GIT_PS1_SHOWUPSTREAM=""
            else
                GIT_PS1_SHOWDIRTYSTATE=true
                GIT_PS1_SHOWSTASHSTATE=true
                GIT_PS1_SHOWUNTRACKEDFILES=true
                GIT_PS1_SHOWUPSTREAM="auto"
            fi
            
            # Curated modern pastel palette (using 256-color modes)
            local red="\[\033[38;5;203m\]"
            local mint="\[\033[38;5;85m\]"
            local sky="\[\033[38;5;117m\]"
            local lavender="\[\033[38;5;141m\]"
            local amber="\[\033[38;5;214m\]"
            local soft_green="\[\033[38;5;120m\]"
            local reset="\[\033[00m\]"
            
            local status_indicator=""
            if [ $exit_code -ne 0 ]; then
                status_indicator="${red}[$exit_code] ${reset}"
            fi
            
            local conda_env=""
            if [[ -n "$CONDA_DEFAULT_ENV" && "$CONDA_DEFAULT_ENV" != "base" ]]; then
                conda_env="${soft_green}(${CONDA_DEFAULT_ENV}) ${reset}"
            fi
            
            _PRE="${status_indicator}${conda_env}${mint}\u@\h${reset}:${sky}\w"
            _POST=" ${amber}${_PROMPT_CHAR}${reset} "
            _FORMAT="${lavender} (%s)"
            return $exit_code
        }
    else
        # Fallback premium prompt if __git_ps1 is unavailable
        _set_bash_fallback_prompt() {
            local exit_code=$?
            local red="\[\033[38;5;203m\]"
            local mint="\[\033[38;5;85m\]"
            local sky="\[\033[38;5;117m\]"
            local lavender="\[\033[38;5;141m\]"
            local amber="\[\033[38;5;214m\]"
            local soft_green="\[\033[38;5;120m\]"
            local reset="\[\033[00m\]"
            
            local status_indicator=""
            if [ $exit_code -ne 0 ]; then
                status_indicator="${red}[$exit_code] ${reset}"
            fi
            
            local conda_env=""
            if [[ -n "$CONDA_DEFAULT_ENV" && "$CONDA_DEFAULT_ENV" != "base" ]]; then
                conda_env="${soft_green}(${CONDA_DEFAULT_ENV}) ${reset}"
            fi
            
            local branch=""
            if $_HAS_GIT && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
                branch="${lavender} ($(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null))"
            fi
            
            PS1="${status_indicator}${conda_env}${mint}\u@\h${reset}:${sky}\w${branch} ${amber}${_PROMPT_CHAR}${reset} "
            return $exit_code
        }
    fi

    # Set PROMPT_COMMAND only if the custom prompt is selected
    if [[ "$SH_PROMPT_STYLE" == "custom" ]]; then
        if declare -F _set_bash_prompt_vars >/dev/null 2>&1; then
            PROMPT_COMMAND='_set_bash_prompt_vars; __git_ps1 "$_PRE" "$_POST" "$_FORMAT"'
        else
            PROMPT_COMMAND="_set_bash_fallback_prompt"
        fi
    fi

elif [[ -n "$ZSH_VERSION" ]]; then    # Zsh built-in Git integration (vcs_info)
    autoload -Uz vcs_info
    precmd_vcs_info() {
        if [[ -n "$WSL_DISTRO_NAME" && "$PWD" == /mnt/* ]]; then
            zstyle ':vcs_info:*' check-for-changes false
        else
            zstyle ':vcs_info:*' check-for-changes true
        fi
        vcs_info
    }
    precmd_functions+=(precmd_vcs_info)
    
    zstyle ':vcs_info:*' enable git
    zstyle ':vcs_info:*' check-for-changes true
    zstyle ':vcs_info:git:*' formats ' (%b%u%c%m)'
    zstyle ':vcs_info:git:*' actionformats ' (%b|%a%u%c%m)'
    zstyle ':vcs_info:git:*' unstagedstr '*'
    zstyle ':vcs_info:git:*' stagedstr '+'
 
    # Zsh vcs_info hooks to check for untracked files, stashes, and upstream status
    +vi-git-untracked() {
        if [[ -n "$WSL_DISTRO_NAME" && "$PWD" == /mnt/* ]]; then
            return 0
        fi
        if git status --porcelain 2>/dev/null | grep -q '^\?\?'; then
            hook_com[unstaged]+='%'
        fi
    }

    +vi-git-stash() {
        if [[ -n "$WSL_DISTRO_NAME" && "$PWD" == /mnt/* ]]; then
            return 0
        fi
        if git rev-parse --verify refs/stash >/dev/null 2>&1; then
            hook_com[misc]+='$'
        fi
    }

    +vi-git-upstream() {
        if [[ -n "$WSL_DISTRO_NAME" && "$PWD" == /mnt/* ]]; then
            return 0
        fi
        local count
        if count=$(git rev-list --left-right --count HEAD...@{upstream} 2>/dev/null); then
            local ahead behind
            read -r ahead behind <<<"$count"
            local upstream_status=""
            if (( ahead > 0 && behind > 0 )); then
                upstream_status="<>"
            elif (( ahead > 0 )); then
                upstream_status=">"
            elif (( behind > 0 )); then
                upstream_status="<"
            fi
            [[ -n "$upstream_status" ]] && hook_com[misc]+=" $upstream_status"
        fi
    }
    
    zstyle ':vcs_info:git*+set-message:*' hooks git-upstream git-stash git-untracked
    
    setopt prompt_subst
    
    # Dynamic Conda environment indicator for Zsh
    _zsh_conda_prompt() {
        if [[ -n "$CONDA_DEFAULT_ENV" && "$CONDA_DEFAULT_ENV" != "base" ]]; then
            echo "%F{120}(${CONDA_DEFAULT_ENV}) %f"
        fi
    }
    
    # Premium styled prompt for Zsh with curated colors (applied only if custom)
    if [[ "$SH_PROMPT_STYLE" == "custom" ]]; then
        PROMPT='%(?..%F{203}[%?] %f)$(_zsh_conda_prompt)%F{85}%n@%m%f:%F{117}%~%f%F{141}${vcs_info_msg_0_}%f %F{214}$_PROMPT_CHAR%f '
    fi
fi


# History (shell-agnostic)
export HISTSIZE=10000
export HISTFILESIZE=20000
export HISTCONTROL=ignoreboth:erasedups
if [[ -n "$BASH_VERSION" ]]; then
    shopt -s histappend
elif [[ -n "$ZSH_VERSION" ]]; then
    setopt HIST_APPEND HIST_IGNORE_DUPS HIST_IGNORE_SPACE
fi

