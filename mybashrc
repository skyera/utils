# =============================================================================
# SOURCES
# =============================================================================
export FORGIT_INSTALL_DIR="$HOME/.local/share/forgit"

if ! $_IS_CONTAINER; then
    # Cache directory for generated init scripts
    CACHE_DIR="$HOME/.cache/bash"
    mkdir -p "$CACHE_DIR"

    if [[ -n "$BASH_VERSION" ]]; then
        # Zoxide caching
        if command -v zoxide >/dev/null 2>&1; then
            if [ ! -f "$CACHE_DIR/zoxide.bash" ]; then
                zoxide init bash > "$CACHE_DIR/zoxide.bash"
            fi
            source "$CACHE_DIR/zoxide.bash"
        fi
        # FZF caching
        if command -v fzf >/dev/null 2>&1; then
            if [ ! -f "$CACHE_DIR/fzf.bash" ]; then
                fzf --bash > "$CACHE_DIR/fzf.bash"
            fi
            source "$CACHE_DIR/fzf.bash"
        fi
    elif [[ -n "$ZSH_VERSION" ]]; then
        # Initialize Zsh completion system if not already done
        if ! type _git >/dev/null 2>&1; then
            autoload -Uz compinit && compinit
        fi
        # Zoxide caching
        if command -v zoxide >/dev/null 2>&1; then
            if [ ! -f "$CACHE_DIR/zoxide.zsh" ]; then
                zoxide init zsh > "$CACHE_DIR/zoxide.zsh"
            fi
            source "$CACHE_DIR/zoxide.zsh"
        fi
        # FZF caching
        if command -v fzf >/dev/null 2>&1; then
            if [ ! -f "$CACHE_DIR/fzf.zsh" ]; then
                fzf --zsh > "$CACHE_DIR/fzf.zsh"
            fi
            source "$CACHE_DIR/fzf.zsh"
        fi
    fi
fi

# =============================================================================
# PLUGINS
# =============================================================================

if ! $_IS_CONTAINER; then
    # Function to check and install missing tools (moved out of hot path)
    check_install_plugins() {
        if ! $_IS_WINDOWS; then
            # Install vim-plug if missing
            if [ ! -f "$HOME/.vim/autoload/plug.vim" ]; then
                echo "Installing vim-plug for Vim..."
                curl -fLo "$HOME/.vim/autoload/plug.vim" --create-dirs \
                    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
            fi

            if [ ! -f "$HOME/.local/share/nvim/site/autoload/plug.vim" ]; then
                echo "Installing vim-plug for Neovim..."
                curl -fLo "$HOME/.local/share/nvim/site/autoload/plug.vim" --create-dirs \
                    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
            fi

            # Install TPM (Tmux Plugin Manager) if missing
            if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
                echo "Installing TPM for Tmux..."
                git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
            fi
        fi

        # Install Hack Nerd Font variations if missing
        if [[ "$_UNAME" == "Darwin" ]]; then
            if [ ! -f "$HOME/Library/Fonts/HackNerdFont-Regular.ttf" ] && \
               [ ! -f "$HOME/Library/Fonts/Hack Nerd Font Complete.ttf" ]; then
                if command -v brew >/dev/null 2>&1; then
                    echo "Installing Hack Nerd Font via Homebrew..."
                    brew install --cask font-hack-nerd-font
                fi
            fi
        elif [[ "$_UNAME" == "Linux" ]]; then
            if [ ! -f "$HOME/.local/share/fonts/HackNerdFont-Regular.ttf" ]; then
                echo "Installing all Hack Nerd Font variations..."
                mkdir -p "$HOME/.local/share/fonts"
                BASE_URL="https://github.com/ryanoasis/nerd-fonts/raw/HEAD/patched-fonts/Hack"
                for style in "" "Mono" "Propo"; do
                    for weight in "Regular" "Bold" "Italic" "BoldItalic"; do
                        FILE="HackNerdFont${style}-${weight}.ttf"
                        curl -sfLo "$HOME/.local/share/fonts/$FILE" "$BASE_URL/${weight}/$FILE"
                    done
                done
                command -v fc-cache >/dev/null 2>&1 && fc-cache -f "$HOME/.local/share/fonts"
            fi
        fi

        PLUGINS_DIR="$HOME/.local/share"
        mkdir -p "$PLUGINS_DIR"

        install_plugin() {
            local repo=$1
            local name=$(basename "$repo")
            local dir="$PLUGINS_DIR/$name"
            if [ ! -d "$dir" ]; then
                echo "Installing $repo..."
                git clone --depth 1 "https://github.com/$repo.git" "$dir"
            fi
        }

        install_plugin "junegunn/fzf-git.sh"
        install_plugin "wfxr/forgit"

        # Ranger Plugins
        if ! $_IS_WINDOWS; then
            RANGER_PLUGIN_DIR="$HOME/.config/ranger/plugins"
            if [ ! -d "$RANGER_PLUGIN_DIR/ranger_devicons" ]; then
                echo "Installing ranger_devicons..."
                mkdir -p "$RANGER_PLUGIN_DIR"
                git clone --depth 1 https://github.com/alexanderjeurissen/ranger_devicons "$RANGER_PLUGIN_DIR/ranger_devicons"
            fi
        fi
    }

    # Only run the heavy check if explicitly requested or if core plugins are missing
    PLUGINS_DIR="$HOME/.local/share"
    if [ ! -d "$PLUGINS_DIR/forgit" ] || [ ! -d "$PLUGINS_DIR/fzf-git.sh" ]; then
        check_install_plugins
    fi

    # Source plugins if they exist
    if [ -f "$PLUGINS_DIR/fzf-git.sh/fzf-git.sh" ]; then
        source "$PLUGINS_DIR/fzf-git.sh/fzf-git.sh"
    fi
    if [ -f "$PLUGINS_DIR/forgit/forgit.plugin.sh" ]; then
        if [[ -n "$BASH_VERSION" ]]; then
            _git_switch_branch() { _git_checkout_branch "$@"; }
            [ -f "$PLUGINS_DIR/forgit/completions/git-forgit.bash" ] && source "$PLUGINS_DIR/forgit/completions/git-forgit.bash"
        elif [[ -n "$ZSH_VERSION" ]]; then
            [ -f "$PLUGINS_DIR/forgit/completions/_git-forgit" ] && source "$PLUGINS_DIR/forgit/completions/_git-forgit"
        fi
        source "$PLUGINS_DIR/forgit/forgit.plugin.sh"
    fi
fi