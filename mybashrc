switch_prompt() {
    local style="$1"
    if [[ "$style" == "oh-my-bash" || "$style" == "omb" ]]; then
        if [[ -n "$BASH_VERSION" ]]; then
            # Remove custom prompt hooks from PROMPT_COMMAND if present
            if declare -p PROMPT_COMMAND 2>/dev/null | grep -q "declare -a"; then
                local new_pc=()
                for pc in "${PROMPT_COMMAND[@]}"; do
                    if [[ "$pc" != *"_set_bash_prompt_vars"* && "$pc" != *"_set_bash_fallback_prompt"* ]]; then
                        new_pc+=("$pc")
                    fi
                done
                PROMPT_COMMAND=("${new_pc[@]}")
            else
                # Clean up prompt vars hook with potential semicolons
                PROMPT_COMMAND="${PROMPT_COMMAND//_set_bash_prompt_vars; __git_ps1 \"\$_PRE\" \"\$_POST\" \"\$_FORMAT\"; /}"
                PROMPT_COMMAND="${PROMPT_COMMAND//; _set_bash_prompt_vars; __git_ps1 \"\$_PRE\" \"\$_POST\" \"\$_FORMAT\"/}"
                PROMPT_COMMAND="${PROMPT_COMMAND//_set_bash_prompt_vars; __git_ps1 \"\$_PRE\" \"\$_POST\" \"\$_FORMAT\"/}"

                # Clean up fallback prompt hook with potential semicolons
                PROMPT_COMMAND="${PROMPT_COMMAND//_set_bash_fallback_prompt; /}"
                PROMPT_COMMAND="${PROMPT_COMMAND//; _set_bash_fallback_prompt/}"
                PROMPT_COMMAND="${PROMPT_COMMAND//_set_bash_fallback_prompt/}"
            fi

            export OSH=$HOME/.oh-my-bash
            if [ ! -d "$OSH" ]; then
                if command -v git >/dev/null 2>&1; then
                    echo -e "\033[32m[mybashrc] ~/.oh-my-bash not found. Automatically cloning oh-my-bash...\033[0m"
                    git clone --depth=1 https://github.com/ohmybash/oh-my-bash.git "$OSH"
                else
                    echo -e "\033[31m[mybashrc] Error: git is required to download oh-my-bash.\033[0m"
                    return 1
                fi
            fi
            
            if [ -f "$OSH/oh-my-bash.sh" ]; then
                export SH_PROMPT_STYLE="oh-my-bash"
                
                # Sourced only once to avoid duplicate hooks, path additions, and warnings
                if ! declare -f _omb_util_add_prompt_command >/dev/null 2>&1; then
                    plugins=($OMB_PLUGINS)
                    aliases=($OMB_ALIASES)
                    completions=($OMB_COMPLETIONS)
                    source "$OSH/oh-my-bash.sh"
                else
                    # If already sourced, ensure the hook is added back to PROMPT_COMMAND
                    if ((BASH_VERSINFO[0] * 10000 + BASH_VERSINFO[1] * 100 + BASH_VERSINFO[2] >= 50100)); then
                        local found=false
                        for pc in "${PROMPT_COMMAND[@]}"; do
                            [[ "$pc" == *"_omb_util_prompt_command_hook"* ]] && found=true
                        done
                        $found || PROMPT_COMMAND+=("_omb_util_prompt_command_hook")
                    else
                        [[ "$PROMPT_COMMAND" == *"_omb_util_prompt_command_hook"* ]] || PROMPT_COMMAND="_omb_util_prompt_command_hook; $PROMPT_COMMAND"
                    fi
                    
                    # Forces re-evaluation of prompt theme PS1 in active session
                    if declare -f _omb_theme_PROMPT_COMMAND >/dev/null 2>&1; then
                        _omb_theme_PROMPT_COMMAND
                    fi
                fi
                
                _apply_overrides
                echo "Switched prompt style to oh-my-bash (Theme: $OSH_THEME)"
            else
                echo "Error: oh-my-bash could not be loaded from $OSH"
            fi
        else
            echo "oh-my-bash is only supported in Bash."
        fi
    elif [[ "$style" == "custom" || "$style" == "my" ]]; then
        export SH_PROMPT_STYLE="custom"
        if [[ -n "$BASH_VERSION" ]]; then
            # Surgically remove oh-my-bash hook from PROMPT_COMMAND if present to preserve other integrations (zoxide, fzf, etc.)
            if declare -p PROMPT_COMMAND 2>/dev/null | grep -q "declare -a"; then
                local new_pc=()
                for pc in "${PROMPT_COMMAND[@]}"; do
                    if [[ "$pc" != *"_omb_util_prompt_command_hook"* ]]; then
                        new_pc+=("$pc")
                    fi
                done
                PROMPT_COMMAND=("${new_pc[@]}")
            else
                PROMPT_COMMAND="${PROMPT_COMMAND//_omb_util_prompt_command_hook; /}"
                PROMPT_COMMAND="${PROMPT_COMMAND//; _omb_util_prompt_command_hook/}"
                PROMPT_COMMAND="${PROMPT_COMMAND//_omb_util_prompt_command_hook/}"
            fi

            # Add custom prompt hook if not already present
            if ((BASH_VERSINFO[0] * 10000 + BASH_VERSINFO[1] * 100 + BASH_VERSINFO[2] >= 50100)); then
                local found=false
                if declare -F _set_bash_prompt_vars >/dev/null 2>&1; then
                    for pc in "${PROMPT_COMMAND[@]}"; do
                        [[ "$pc" == *"_set_bash_prompt_vars"* ]] && found=true
                    done
                    $found || PROMPT_COMMAND+=('_set_bash_prompt_vars; __git_ps1 "$_PRE" "$_POST" "$_FORMAT"')
                else
                    for pc in "${PROMPT_COMMAND[@]}"; do
                        [[ "$pc" == *"_set_bash_fallback_prompt"* ]] && found=true
                    done
                    $found || PROMPT_COMMAND+=("_set_bash_fallback_prompt")
                fi
            else
                if declare -F _set_bash_prompt_vars >/dev/null 2>&1; then
                    [[ "$PROMPT_COMMAND" == *"_set_bash_prompt_vars"* ]] || PROMPT_COMMAND='_set_bash_prompt_vars; __git_ps1 "$_PRE" "$_POST" "$_FORMAT"'
                else
                    [[ "$PROMPT_COMMAND" == *"_set_bash_fallback_prompt"* ]] || PROMPT_COMMAND="_set_bash_fallback_prompt"
                fi
            fi
            echo "Switched prompt style to custom mybashrc prompt."
        elif [[ -n "$ZSH_VERSION" ]]; then
            PROMPT='%(?..%F{203}[%?] %f)$(_zsh_conda_prompt)%F{85}%n@%m%f:%F{117}%~%f%F{141}${vcs_info_msg_0_}%f %F{214}$_PROMPT_CHAR%f '
            echo "Switched prompt style to custom mybashrc prompt."
        fi
    else
        echo "Usage: switch_prompt [custom | oh-my-bash]"
        echo "Current style: $SH_PROMPT_STYLE"
    fi
}

