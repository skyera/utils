#!/bin/bash
# git-fuzzy - Interactive git browser using fzf and delta

set -e

# Check for fzf and delta
if ! command -v fzf >/dev/null 2>&1; then
    echo "Error: fzf is not installed."
    exit 1
fi

if ! command -v delta >/dev/null 2>&1; then
    DELTA_CMD="cat"
else
    DELTA_CMD="delta --width=$COLUMNS"
fi

show_help() {
    echo "Usage: git-fuzzy [command]"
    echo ""
    echo "Commands:"
    echo "  branch (b)  - Browse and checkout branches"
    echo "  stash (s)   - Browse and apply/drop stashes"
    echo "  log (l)     - Browse commit history"
    echo "  diff (d)    - Interactive diff of changed files"
    echo "  help (h)    - Show this help"
}

browse_branches() {
    local branch
    branch=$(git branch -a --color=always | grep -v '/HEAD' | \
        fzf --ansi --preview "git log --oneline --graph --color=always \$(echo {} | sed 's/..//' | cut -d' ' -f1) | head -n 50" \
            --header "Enter: Checkout | Ctrl-d: Delete | Ctrl-o: Origin")
    
    if [[ -n "$branch" ]]; then
        branch_name=$(echo "$branch" | sed 's/..//' | cut -d' ' -f1)
        git checkout "$branch_name"
    fi
}

browse_stashes() {
    local stash
    stash=$(git stash list --color=always | \
        fzf --ansi --preview "git stash show -p --color=always \$(echo {} | cut -d: -f1) | $DELTA_CMD" \
            --header "Enter: Apply | Ctrl-d: Drop | Ctrl-b: Branch")
    
    if [[ -n "$stash" ]]; then
        stash_id=$(echo "$stash" | cut -d: -f1)
        read -p "Apply $stash_id? (y/n): " confirm
        [[ "$confirm" == "y" ]] && git stash apply "$stash_id"
    fi
}

browse_log() {
    git log --graph --color=always --format="%C(auto)%h%d %s %C(black)%C(bold)%cr" "$@" | \
        fzf --ansi --no-sort --reverse --multi --header "Enter: Show Details | Ctrl-d: Diff" \
            --preview "echo {} | grep -o '[a-f0-9]\{7\}' | head -1 | xargs -I % git show --color=always % | $DELTA_CMD" \
            --bind "enter:execute(echo {} | grep -o '[a-f0-9]\{7\}' | head -1 | xargs -I % sh -c 'git show % | $DELTA_CMD | less -R')"
}

interactive_diff() {
    local file
    file=$(git status --short | fzf --ansi --preview "git diff --color=always \$(echo {} | cut -c4-) | $DELTA_CMD")
    if [[ -n "$file" ]]; then
        file_path=$(echo "$file" | cut -c4-)
        ${EDITOR:-nvim} "$file_path"
    fi
}

case "$1" in
    branch|b) browse_branches ;;
    stash|s)  browse_stashes ;;
    log|l)    browse_log ;;
    diff|d)   interactive_diff ;;
    "")       browse_log ;;
    *)        show_help ;;
esac
