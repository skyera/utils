" Enable preview mode on startup
view!
set vifminfo+=tui

" --- File Viewers ---
" Use eza/ls for directories and bat for files.
" We handle this in a single rule to ensure correct precedence and avoid bat errors on folders.
fileviewer *
    \ if [ -d %c ]; then (eza --tree --icons=always --color=always %c || ls -F --color=always %c) | head -200;
    \ else bat --color=always --style=numbers %c; fi

" --- Keybindings ---
" Toggle preview with 'w'
nnoremap w :view!<cr>
" Map 's' to FZF search
nnoremap s :FZFfind<cr>
" Quick quit
nnoremap q :q<cr>

" --- Commands ---
" Cross-platform FZFfind
if $OS == 'Windows_NT'
    " Windows: Expects vifm_fzf_find.bat to be in PATH (installed via deploy.sh)
    command! FZFfind :execute '!vifm_fzf_find.bat %u'
else
    " Linux/macOS: Run inline fzf with a robust preview window
    command! FZFfind :let $FZF_PICK = term('fd --follow --hidden --exclude .git | fzf --preview "if [ -d {} ]; then eza --tree --color=always {} | head -200; else bat --color=always --style=numbers {}; fi" 2>/dev/tty') | if $FZF_PICK != '' | execute 'goto' fnameescape($FZF_PICK) | endif
endif
