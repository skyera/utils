" Enable preview mode on startup
view!
set vifminfo+=tui

" --- File Viewers ---
" Preview directories with ls
fileviewer */,**/ ls --color=always %c

" Preview everything else with bat
" bat handles binary files and unknown extensions gracefully
fileviewer * bat --color=always --style=numbers %c

" --- Keybindings ---
" Toggle preview with 'w'
nnoremap w :view!<cr>
" Map 's' to FZF search
nnoremap s :FZFfind<cr>
" Quick quit
nnoremap q :q<cr>

" --- Commands ---
" Cross-platform FZFfind
if $OS == 'Windows_NT'
    " Windows: Expects vifm_fzf_find.bat to be in PATH (installed via deploy.sh)
    command! FZFfind :execute '!vifm_fzf_find.bat %u'
else
    " Linux/macOS: Run inline fzf with a preview window
    command! FZFfind :let $FZF_PICK = term('fd . --type f | fzf --preview "bat --color=always --style=numbers {}" 2>/dev/tty') | if $FZF_PICK != '' | execute 'goto' fnameescape($FZF_PICK) | endif
endif
