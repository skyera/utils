# --- Visuals & Layout ---
set vertical-split = yes
set main-view-line-number = yes
set diff-view-line-number = yes
set tab-size = 4

# Fixed main-view: graph is an option of commit-title, not a separate column
set main-view = date:default author:email-user,maxwidth=15 id:yes,color commit-title:graph=yes,refs=yes

color date             cyan   black
color cursor           black  yellow bold
color author           yellow default
color "---"            red    default
color "+++"            green  default
color "+ "             green  default
color "- "             red    default

# --- Behavior ---
set ignore-case = yes
set wrap-search = yes
set refresh-mode = auto
set diff-options = -C5 --diff-merges=m

# --- Keybindings ---
# General Navigation
# (C-f, C-b, C-d, C-u, C-e, C-y are Tig defaults, so we only add arrow-key variants)
bind generic <C-Down> scroll-line-down
bind generic <C-Up>   scroll-line-up

# Actions
bind generic W     :toggle diff-options --ignore-all-space
bind generic Y     !@sh -c "echo -n %(commit) | ~/test/utils/bin/osc52-yank.sh"
bind generic V     !nvim +%(line) %(file)
