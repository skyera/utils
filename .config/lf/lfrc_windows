#C:\Users\xxx\AppData\Local\lf\lfrc
# this goes in $env:USERPROFILE\AppData\Local\lf\lfrc
# personally, I symlink it from my synced config files like this:
# cmd /c mklink lfrc $env:OneDriveConsumer\configs\dot-config-lf\lfrc.windows
 
# winget install gokcehan.lf sharkdp.bat zoxide fzf vim.vim
# If you want to use the GUI quicklook tool to preview images / docs with `V`:
# winget install QL-Win.QuickLook
 
# Include default configuration first, then override with Windows-specific settings
source %LOCALAPPDATA%\lf\lfrc.default

# interpreter for shell commands
set shell powershell
 
# change the default open command to work in powerShell
#cmd open &start $Env:f
# edit with nvim if exists, else vim
map e $if (Get-Command nvim -ErrorAction SilentlyContinue) { nvim $env:f } else { vim $env:f }
map <enter> $if (Get-Command nvim -ErrorAction SilentlyContinue) { nvim $env:f } else { vim $env:f }
# page through any file with bat
# paging=always so that shorter files don't immediately exit back to lf
map i $bat --paging=always $Env:f
# use "bat -p" (plain pager) also for viewing lf docs
cmd doc $lf -doc | bat -p
 
# on my powershell 7.4.6 this breaks, commenting out
#set shellflag "-cwa"
 
# refine selected file as I type
set incsearch true
set number true
set preview true
set previewer 'c:\app\bin\lf-preview.bat'
set drawbox true

# Window layout and appearance
set ratios 1:3:4          # Larger preview area (left:preview:right)
set info size:time         # Show file size and modification time
set dircounts true         # Show file counts in directories
set hidden false           # Hidden files off by default (toggle with zh)
map <m-1> select
 
# default, but with some separation before final %f, and after cwd
# otherwise I kept on interpreting cwd+file as cwd
# 💾 📁
set promptfmt "\033[32;1m%u@%h\033[0m:\033[36;1m%d 📁 \033[0m\033[1m%f\033[0m"
 
# https://github.com/gokcehan/lf/wiki/Integrations#quicklook
# winget install QL-Win.QuickLook
map V $ & "$env:LOCALAPPDATA\Programs\QuickLook\QuickLook.exe" "$env:f"
 
cmd fzf_find $C:/app/bin/fzf_find.bat
map f :fzf_find

# --- Navigation ---
# Freeze the starting directory at load time using a sync shell call
# We use $env:id and $PWD since shell is set to powershell
$lf -remote "send $env:id cmd go_origin cd '$PWD'"
map go :go_origin

set icons true
# https://github.com/gokcehan/lf/blob/master/etc/icons.example -> %LOCALAPPDATA%\lf\icons
map <c-c> $echo -n $env:f | clip

# Filter commands (using Shift+F to avoid conflict with fzf_find)
map F filter
cmd filter %{{
    lf -remote "send $env:id set filter `$*`"
    lf -remote "send $env:id echo Filter: `$*`"
}}

