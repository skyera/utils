# .config/lf/lfrc

# Include default configuration
source ~/.config/lf/lfrc.default

set shell bash
map e $$EDITOR $f
map <enter> $$EDITOR $f

map i $bat --paging=always $f
cmd doc $lf -doc | bat -p

set incsearch true
set number true
set preview true
set previewer ~/bin/lf-preview.sh
set drawbox true

# Enhanced shell settings for better UX
set shellopts '-eu'          # Safer shell execution
set scrolloff 10            # Keep cursor centered
set smartcase true          # Smart case sensitivity

# Window layout and appearance
set ratios 1:3:4          # Larger preview area (left:preview:right)
set info size:time         # Show file size and modification time
set dircounts true         # Show file counts in directories
set hidden false           # Hidden files off by default (toggle with zh)
map <m-1> select
cmd fzf_find $~/bin/fzf_find.sh
map f :fzf_find

# Filter commands (using Shift+F to avoid conflict with fzf_find)
map F filter


# --- Navigation ---
# Freeze the starting directory at load time using a sync shell call
$lf -remote "send $id cmd go_origin cd '$(pwd)'"
map go :go_origin

# https://github.com/gokcehan/lf/blob/master/etc/icons.example->~/.config/lf/icons
set icons true

# Enhanced utility commands
cmd mkdir %{{
    mkdir -p "$1"
    lf -remote "send $id reload"
}}

cmd touch %{{
    touch "$1"
    lf -remote "send $id reload"
}}

# Safe delete with confirmation
cmd delete %{{
    lf -remote "send $id echo 'Delete $fx? (y/n)'"
    read -r ans
    [ "$ans" = "y" ] && rm -rf $fx
}}

